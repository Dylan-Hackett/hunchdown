{
  "platform": "instagram",
  "post_style": "single_post",
  "url_patterns": ["instagram\\.com/(p|reel|tv)/[^/?#]+"],
  "components": ["post"],
  "crop": {
    "left_pct": 15.0,
    "top_pct": 10.0,
    "right_pct": 15.0,
    "bottom_pct": 8.0
  },
  "size": { "mode": "fixed_width", "width_inches": 6.0 },
  "notes": "Per-capture CV detects the post region (media + sidebar). Static crop above is fallback when CV fails.",
  "created_by": "Dylan Hackett",
  "created_at": "2026-05-29"
}
